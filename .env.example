# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here

# The role whose members can use all bot commands
DESIGNATED_ROLE_ID=123456789012345678

# Your Discord user ID — grants admin-only commands
ADMIN_USER_ID=123456789012345678

# ── Feedback channels ─────────────────────────────────────────────────────────
BUG_CHANNEL_ID=123456789012345678
FEATURE_CHANNEL_ID=123456789012345678

# ── Bot behaviour ─────────────────────────────────────────────────────────────
COMMAND_PREFIX=!
DEFAULT_VOLUME=70
# Seconds of inactivity before the bot auto-leaves the voice channel
INACTIVITY_TIMEOUT=180

# ── Spotify (optional) ───────────────────────────────────────────────────────
# Required only for Spotify URL support.
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
