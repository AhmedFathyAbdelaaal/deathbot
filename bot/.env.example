# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here

# The role whose members can use all bot commands
DESIGNATED_ROLE_ID=123456789012345678

# Your Discord user ID — grants admin-only commands
ADMIN_USER_ID=123456789012345678

# ── Feedback channels ─────────────────────────────────────────────────────────
BUG_CHANNEL_ID=123456789012345678
FEATURE_CHANNEL_ID=123456789012345678

# ── Bot behaviour ─────────────────────────────────────────────────────────────
COMMAND_PREFIX=!
DEFAULT_VOLUME=70
# Seconds of inactivity before the bot auto-leaves the voice channel
INACTIVITY_TIMEOUT=180

# ── Spotify (optional) ───────────────────────────────────────────────────────
# Required only for Spotify URL support.
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Web platform (FastAPI + Postgres) ────────────────────────────────────────
# Full reference: deathbot-env-vars.md
# Postgres connection string from the Coolify Postgres resource. The bare
# 'postgres://' scheme is normalized to 'postgresql+asyncpg://' in code.
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Where the uploads persistent volume is mounted inside the container.
UPLOADS_PATH=/data/deathbot/uploads
# Port the FastAPI/uvicorn server listens on (must match EXPOSE + Coolify route).
API_PORT=8000
# Digits in a generated access pin.
PIN_LENGTH=4
# Used by /website to build the link sent to the user.
WEB_BASE_URL=https://deathbot.captionato.tech
# The single allowed frontend origin (API is public, so no wildcard).
CORS_ALLOWED_ORIGIN=https://deathbot.captionato.tech
# Upload size cap in bytes (250 MB).
UPLOAD_MAX_BYTES=262144000
